# --- Secrets & local config ---------------------------------------------------
.env
.env.*
!.env.example
k8s/secret.yaml

# --- Python (backend) ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# Runtime data (SQLite, ChromaDB, user uploads)
backend/sql_app.db
backend/chroma_db/
backend/uploads/
sql_app.db
chroma_db/
uploads/

# --- Node / frontend ----------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# --- Logs ---------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- IDE & OS -----------------------------------------------------------------
.run/
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db
Desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
